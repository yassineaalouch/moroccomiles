// =========================================
// REVIEWS
// =========================================
model Review {
  id             Int       @id @default(autoincrement())
  rating         Int       // 1 à 5
  comment        String
  carId          Int
  userId         Int
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id])
  car            Car       @relation(fields: [carId], references: [id])
}
